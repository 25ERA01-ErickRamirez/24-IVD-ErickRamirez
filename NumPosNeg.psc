//Verificar si un ALOR ES POSITIVO O NEGATIVO
Algoritmo NumPosNeg	
	//entrada
	Escribir "==Numeros Positivos o negativos=="
	Definir num Como Entero
	Escribir "Dame un numero entero;"
	Leer num
	
	//Proceso
	//Salida
	Si num>=0 Entonces
		Escribir "Es un numero positivo"
	SiNo
		Escribir "Es un numero negativo"
	Fin Si
	
	
FinAlgoritmo